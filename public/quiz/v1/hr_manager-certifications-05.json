      "scenario_id": "SC01",
      "title": "Nykaa Store Team Friction",
      "questions": [
        {
          "q_id": "SC01_Q01",
          "q": "New HR Manager at Nykaa: Store Team Friction. First move in 60 mins?",
          "explain_this": "Triage: clarify impact, owner, timeline, minimum facts.",
          "options": [
            {
              "text": "Define scope + pull 3 key data points",
              "feedback": "You frame impact → alignment speeds up."
            },
            {
              "text": "Send a broad policy reminder",
              "feedback": "You go generic → root cause stays hidden."
            },
            {
              "text": "Launch a long survey now",
              "feedback": "You add delay → issue compounds."
            },
            {
              "text": "Ask teams to handle locally",
              "feedback": "You lose visibility → actions fragment."
            }
          ],
          "correct_index": 0
        },
        {
          "q_id": "SC01_Q02",
          "q": "Signals are mixed in Nykaa. Safest next step?",
          "explain_this": "Containment: reduce harm now while verifying facts.",
          "options": [
            {
              "text": "Separate facts vs claims; list gaps",
              "feedback": "You stay neutral → proof path opens."
            },
            {
              "text": "Assume senior version is true",
              "feedback": "You bias early → decision gets challenged."
            },
            {
              "text": "Wait for perfect information",
              "feedback": "You delay action → risk grows."
            },
            {
              "text": "Share raw details widely",
              "feedback": "You overshare → privacy risk rises."
            }
          ],
          "correct_index": 0
        },
        {
          "q_id": "SC01_Q03",
          "q": "Leadership asks for plan by EOD. What format wins trust?",
          "explain_this": "Decision memo: options, trade-offs, recommendation, checkpoint.",
          "options": [
            {
              "text": "Options + trade-offs + recommendation",
              "feedback": "You enable decision → pace improves."
            },
            {
              "text": "Long narrative with screenshots",
              "feedback": "You add noise → decision slows."
            },
            {
              "text": "Only your preferred option",
              "feedback": "You hide trade-offs → pushback increases."
            },
            {
              "text": "Raw complaints pasted as-is",
              "feedback": "You share inputs → no action path."
            }
          ],
          "correct_index": 0
        }
      ]
